<Window x:Class="FanControlPortable.DriverNoticeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="缺少 PawnIO 驱动"
        Width="560"
        Height="292"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBrush}">
    <Border Margin="22" Style="{StaticResource PanelCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
                <RowDefinition Height="34" />
                <RowDefinition Height="46" />
            </Grid.RowDefinitions>

            <TextBlock Text="需要安装 PawnIO 驱动"
                       FontSize="17"
                       FontWeight="SemiBold" />

            <TextBlock Grid.Row="1"
                       Margin="0,10,0,0"
                       Foreground="{StaticResource MutedBrush}"
                       TextWrapping="Wrap"
                       LineHeight="21"
                       Text="当前系统没有检测到 PawnIO。LibreHardwareMonitor 读取部分 CPU 温度、频率、功耗时可能失败，自动风扇控制也可能缺少 CPU 温度参考。&#x0a;&#x0a;软件包内已放入 PawnIO_setup.exe。可以现在打开安装包；安装完成后建议重启本软件。" />

            <TextBlock x:Name="InstallerPathText"
                       Grid.Row="2"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12" />

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">
                <Button x:Name="InstallButton"
                        Style="{StaticResource PrimaryPillButton}"
                        Content="打开安装包"
                        Margin="0,0,10,0"
                        Click="InstallButton_Click" />
                <Button Style="{StaticResource PillButton}"
                        Content="稍后"
                        Click="LaterButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
