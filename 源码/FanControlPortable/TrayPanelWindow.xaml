<Window x:Class="FanControlPortable.TrayPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Width="366"
        Height="360"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#11151B"
        Deactivated="Window_Deactivated"
        Loaded="Window_Loaded">
    <Border CornerRadius="20" BorderBrush="#3D4656" BorderThickness="1" Background="#11151B">
        <wv2:WebView2 x:Name="Browser" DefaultBackgroundColor="#11151B" Margin="1" />
    </Border>
</Window>
